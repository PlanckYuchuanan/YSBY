# YSBY Project Environment Variables

# ============ 数据库 ============
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=ysby_user
MYSQL_PASSWORD=ysby_password
MYSQL_DATABASE=ysby

# ============ Redis ============
REDIS_URL=redis://localhost:6379

# ============ JWT ============
JWT_SECRET=your-secret-key-change-in-production

# ============ 服务端口 ============
PORT=3000
WS_PORT=8080

# ============ 外部服务 ============
# 视频存储 CDN
VIDEO_CDN_URL=https://your-cdn.example.com
# 短信服务
SMS_PROVIDER=aliyun
SMS_ACCESS_KEY=your-access-key
SMS_ACCESS_SECRET=your-access-secret

# ============ API地址 ============
# API 基础地址
API_BASE_URL=http://localhost:3000
# WebSocket 地址
WS_BASE_URL=ws://localhost:8080
